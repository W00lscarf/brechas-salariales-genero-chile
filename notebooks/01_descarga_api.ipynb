{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01 · Descarga de brechas salariales — SIMEL API\n",
    "\n",
    "El SIMEL-INE publica 10 datasets sobre brecha salarial de género con distintas desagregaciones.\n",
    "Este notebook los descarga todos y hace una exploración inicial de la estructura."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from simel_client import SIMELClient\n",
    "\n",
    "sns.set_theme(style='whitegrid')\n",
    "pd.set_option('display.float_format', '{:.2f}'.format)\n",
    "\n",
    "client = SIMELClient()\n",
    "print('Cliente SIMEL listo.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATASETS = [\n",
    "    'DF_BGYMEDIOOCU',           # brecha ingreso medio por región\n",
    "    'DF_BGYMEDIOOCU_EDU',       # por nivel educativo\n",
    "    'DF_BGYMEDIOOCU_EDAD',      # por tramo etario\n",
    "    'DF_BGYMEDIOOCU_RAMA',      # por rama de actividad económica\n",
    "    'DF_BGYMEDIOOCU_CIUO',      # por grupo ocupacional\n",
    "    'DF_BGYMEDIOOCU_TRAMOHORA', # por tramo de horas trabajadas\n",
    "    'DF_BGYMEDIOOCU_CISE',      # por categoría ocupacional\n",
    "    'DF_BGYHDEP_CISE_EDU',      # brecha por hora según educación\n",
    "    'DF_BGYHDEP_CISE_EDAD',     # brecha por hora según edad\n",
    "    'DF_BGREIMPROMSP',          # brecha en remuneración imponible (AFP)\n",
    "]\n",
    "\n",
    "print('Descargando 10 datasets de brecha salarial desde SIMEL-INE...')\n",
    "datos = client.get_multiple(DATASETS)\n",
    "\n",
    "import os\n",
    "os.makedirs('../data', exist_ok=True)\n",
    "for nombre, df in datos.items():\n",
    "    df.to_csv(f'../data/{nombre}.csv', index=False, encoding='utf-8-sig')\n",
    "print('\\nDatos guardados en data/')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Entender el indicador: qué significa la brecha\n",
    "\n",
    "El indicador BGYMEDIOOCU mide:\n",
    "\n",
    "$$\\text{Brecha} = \\frac{\\text{Ingreso}_H - \\text{Ingreso}_M}{\\text{Ingreso}_H} \\times 100$$\n",
    "\n",
    "- **Positivo**: los hombres ganan más (situación habitual)\n",
    "- **Negativo**: las mujeres ganan más (ocurre en algunos grupos muy específicos)\n",
    "- **Cero**: paridad perfecta"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Brecha nacional por año (total)\n",
    "brecha_total = datos['DF_BGYMEDIOOCU'].copy()\n",
    "print('Columnas:', brecha_total.columns.tolist())\n",
    "print('Regiones:', brecha_total['AREA_REF'].unique())\n",
    "print()\n",
    "\n",
    "nacional = brecha_total[brecha_total['AREA_REF'] == '_T'].sort_values('AÑO')\n",
    "print('Evolución brecha salarial nacional:')\n",
    "print(nacional[['AÑO', 'OBS_VALUE']].to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evolución temporal de la brecha nacional\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "ax.plot(nacional['AÑO'], nacional['OBS_VALUE'], 'o-', color='#8e44ad', linewidth=2, markersize=6)\n",
    "ax.fill_between(nacional['AÑO'], nacional['OBS_VALUE'], alpha=0.15, color='#8e44ad')\n",
    "ax.axhline(0, color='gray', linewidth=0.8, linestyle='--')\n",
    "\n",
    "# Anotar último valor\n",
    "ultimo = nacional.iloc[-1]\n",
    "ax.annotate(f\"{ultimo['OBS_VALUE']:.1f}%\",\n",
    "            xy=(ultimo['AÑO'], ultimo['OBS_VALUE']),\n",
    "            xytext=(10, -15), textcoords='offset points',\n",
    "            fontsize=11, fontweight='bold', color='#8e44ad')\n",
    "\n",
    "ax.set_title('Evolución brecha salarial de género — Chile nacional\\n(% del ingreso masculino)',\n",
    "             fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('Brecha (%)')\n",
    "ax.set_xlabel('Año')\n",
    "ax.set_xticks(nacional['AÑO'].unique())\n",
    "plt.setp(ax.get_xticklabels(), rotation=45)\n",
    "sns.despine()\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/brecha_nacional_evolucion.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Brecha por región: ¿dónde es mayor la desigualdad?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "anio_max = brecha_total['AÑO'].max()\n",
    "regional = (\n",
    "    brecha_total[(brecha_total['AÑO'] == anio_max) & (brecha_total['AREA_REF'] != '_T')]\n",
    "    .sort_values('OBS_VALUE', ascending=False)\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "colores_bar = ['#c0392b' if v > 20 else '#e67e22' if v > 10 else '#2e86c1'\n",
    "               for v in regional['OBS_VALUE']]\n",
    "ax.barh(regional['REGION'], regional['OBS_VALUE'], color=colores_bar, edgecolor='white')\n",
    "ax.axvline(regional['OBS_VALUE'].mean(), color='gray', linestyle='--',\n",
    "           label=f\"Promedio nacional ({regional['OBS_VALUE'].mean():.1f}%)\")\n",
    "ax.set_title(f'Brecha salarial de género por región — {anio_max}',\n",
    "             fontsize=12, fontweight='bold')\n",
    "ax.set_xlabel('Brecha (% del ingreso masculino)')\n",
    "ax.legend(fontsize=9)\n",
    "sns.despine()\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/brecha_por_region.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. La paradoja de la educación: más estudios, ¿mayor o menor brecha?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "brecha_edu = datos['DF_BGYMEDIOOCU_EDU'].copy()\n",
    "print('Columnas:', brecha_edu.columns.tolist())\n",
    "print('Niveles educativos:', brecha_edu['EDU'].unique())\n",
    "brecha_edu.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Brecha por educación — año más reciente, nivel nacional\n",
    "anio_max_edu = brecha_edu['AÑO'].max()\n",
    "edu_nac = brecha_edu[\n",
    "    (brecha_edu['AÑO'] == anio_max_edu) &\n",
    "    (brecha_edu['AREA_REF'] == '_T') &\n",
    "    (brecha_edu['EDU'] != '_T')\n",
    "].sort_values('OBS_VALUE', ascending=False)\n",
    "\n",
    "ORDEN_EDU = ['CINE97_X0', 'CINE97_1', 'CINE97_2', 'CINE97_4', 'CINE97_5', 'CINE97_U']\n",
    "edu_nac['orden'] = edu_nac['EDU'].map({k: i for i, k in enumerate(ORDEN_EDU)})\n",
    "edu_nac = edu_nac.sort_values('orden')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "colores_bar = ['#c0392b' if v > 20 else '#e67e22' if v > 0 else '#27ae60'\n",
    "               for v in edu_nac['OBS_VALUE']]\n",
    "ax.bar(edu_nac['EDU_LABEL'], edu_nac['OBS_VALUE'], color=colores_bar, edgecolor='white')\n",
    "ax.axhline(0, color='gray', linewidth=0.8)\n",
    "ax.set_title(f'Brecha salarial por nivel educativo — {anio_max_edu}',\n",
    "             fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('Brecha (% del ingreso masculino)')\n",
    "ax.set_xlabel('Nivel educativo (de menor a mayor)')\n",
    "plt.setp(ax.get_xticklabels(), rotation=30, ha='right')\n",
    "sns.despine()\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/brecha_por_educacion.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Resumen de todos los datasets descargados"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "resumen = pd.DataFrame([\n",
    "    {'Dataset': k, 'Filas': len(v), 'Período': f\"{v['AÑO'].min():.0f}–{v['AÑO'].max():.0f}\" if 'AÑO' in v.columns else '—',\n",
    "     'Columnas': ', '.join(v.columns[:6])}\n",
    "    for k, v in datos.items()\n",
    "])\n",
    "print(resumen.to_string(index=False))"
   ]
  }
 ],
